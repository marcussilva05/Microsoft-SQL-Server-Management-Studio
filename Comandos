-- CriaГ§ГЈo de e-mails
SELECT TOP 10 *, -- Seleciona as 10 primeiras linhas da consulta, e todas as colunas (*)            
              CASE  -- Inicia um CASE para lГіgica condicional                  
                  WHEN CATESC='VINCULADA' THEN -- CondiГ§ГЈo: quando a coluna CATESC for igual a 'VINCULADA' entГЈo
                      CONCAT('e', FORMAT(ESCVINC, '000000'), 'a@educacao.sp.gov.br') -- Se acima for verdadeiro: cria um email concatenando String 'e' com o nГәmero de ESCVINC em 6 dГӯgitos (preenche com zeros Г  esquerda se ESCVINC < 6 dГӯgitos) concatena com String 'a@educacao.sp.gov.br'                
                  ELSE -- Se falso:
                      CONCAT('e', FORMAT(CODESC, '000000'), 'a@educacao.sp.gov.br')   -- cria um email concatenando String 'e' com o nГәmero de CODESC em 6 dГӯgitos (preenche com zeros Г  esquerda se CODESC < 6 dГӯgitos) concatena com String 'a@educacao.sp.gov.br'      
              END               
              AS EMAIL -- Nome da nova coluna calculada como 'EMAIL'
FROM dbo.nome_do_esquema -- Especifica a tabela de origem com esquema dbo

-- extrair zeros de RG
SELECT 
    -- Exemplo: pegar apenas os primeiros 12 caracteres do RG
    LEFT(NR_RG, 12) AS RG_TRUNCADO,
    -- Exemplo prГЎtico com nomes: primeiras 3 letras da URE
    LEFT(NOME_URE, 3) AS SIGLA_URE,
    -- Exemplo: cГіdigo reduzido (primeiros 3 dГӯgitos)
    LEFT(CODESC, 3) AS PREFIXO_CODIGO,
    -- Combine com outras funГ§Гөes
    CONCAT(
        LEFT(NOME_URE, 3),  -- Primeiras 3 letras da URE
        '-',
        LEFT(NOMESC, 10)    -- Primeiras 10 letras da escola
    ) AS CODIGO_REDUZIDO
FROM #ESCOLAS A;

