{	
	//QUERY COLETIVA
	"QUERY COLETIVA": {
		"scope": "sql",
		"prefix": "ZCOLET",
		"body": [
			"--QUERY COLETIVA",
			"/*",
			"	SOLICITAÇÃO",
			"${1:COLE O TEXTO AQUI}",
			"*/",
			"-------------- SCRIPT COLETIVO --------------",
			"",
			"-------------- SCRIPT COLETIVO FIM --------------"
		],
		"description": "QUERY COLETIVA"
	},

	//SELECT
	"QUANTIDADE_DE_CARACTERES": {
		"scope": "sql",
		"prefix": "ZSEL",
		"body": [
			"SELECT *",
			"FROM CTG${1:02}26"
		],
		"description": "CONTA A QUANTIDADE DE CARACTERES"
	},

	//USE_CEPEA_SAS
	"USE_CEPEA_SAS": {
		"scope": "sql",
		"prefix": "ZUSE",
		"body": [
			"USE ${1:CEPEA_SAS}"
		],
		"description": "USE_CEPEA_SAS"
	},

	//TOP_10
	"TOP_10": {
		"scope": "sql",
		"prefix": "ZTOP",
		"body": [
			"SELECT TOP 10*",
			"FROM CTG${1:02}26"
		],
		"description": "TOP_10"
	},

	//QUANTIDADE_DE_CARACTERES
	"QUANTIDADE_DE_CARACTERES": {
		"scope": "sql",
		"prefix": "ZQTDCHAR",
		"body": [
			"DATALENGTH(${1:coluna1}) AS BYTE"
		],
		"description": "CONTA A QUANTIDADE DE CARACTERES"
	}, 

	//RENOMEAR_TABELA
	"RENOMEAR_TABELA": {
		"scope": "sql",
		"prefix": "ZRENTAB",
		"body": [
			"EXEC sp_rename '${1:nome_atual}', '${2:novo_nome}'"
		],
		"description": "RENOMEIA TABELA"
	},

	//BACKUP_DE_BD
	"BACKUP_DE_BD": {
		"scope": "sql",
		"prefix": "ZBKPBD",
		"body": [
			"BACKUP DATABASE ${1:CNOME_BD} TO DISK = 'C:\ENDERECO_COMPLETO\NOME_BANCO_BACKUP.bak'"
		],
		"description": "BACKUP_DE_BD"
	},

	//BACKUP_DE_TABELA
	"BACKUP_DE_TABELA": {
		"scope": "sql",
		"prefix": "ZBKPTAB",
		"body": [
			"INTO ${1:BD}_BKP_${2:DD}_${3:MM}_202${3:6}",
			"FROM ${4:BD}"
		],
		"description": "BACKUP_DE_TABELA"
	},

	//CONCATENAR
	"CONCATENAR": {
		"scope": "sql",
		"prefix": "ZCONC",
		"body": [
			"CONCAT('${1:col1}', '${2:col2}')"
		],
		"description": "CONCATENAR"
	},

	//EXTRAIR_CARACTERES_DA_ESQUERDA_OU_DIREITA
	"EXTRAIR_CARACTERES_DA_ESQUERDA_OU_DIREITA": {
		"scope": "sql",
		"prefix": "ZEXTRCHAR",
		"body": [
			"${1:LEFT}${2:RIGHT}(${3:coluna}, ${4:3}) AS ${5:EXTRACAO_ESQUERDA}"
		],
		"description": "EXTRAIR_CARACTERES_DA_ESQUERDA_OU_DIREITA"
	},

	//LIMPAR_ESPACOS_VAZIOS_DA_ESQUERDA_OU_DIREITA
	"LIMPAR_ESPACOS_VAZIOS_DA_ESQUERDA_OU_DIREITA": {
		"scope": "sql",
		"prefix": "ZLIMP",
		"body": [
			"${1:LTRIM}${2:RTRIM}(${3:COLUNA}) AS LIMPA_${4:ESQUERDA}${5:DIREITA}"
		],
		"description": "LIMPAR_ESPACOS_VAZIOS_DA_ESQUERDA_OU_DIREITA"
	},

	//LIMPAR_TODOS_OS_ESPACOS_VAZIOS
	"LIMPAR_TODOS_OS_ESPACOS_VAZIOS": {
		"scope": "sql",
		"prefix": "ZLIMP",
		"body": [
			"TRIM('     SQL Tutorial!     ') AS SEM_ESPACOS"
		],
		"description": "LIMPAR_TODOS_OS_ESPACOS_VAZIOS"
	},

	//MUDAR_CARACTER_POR_OUTRO
	"MUDAR_CARACTER_POR_OUTRO": {
		"scope": "sql",
		"prefix": "ZMUDCHAR",
		"body": [
			"REPLACE(${1:colnua1}, '${2:T}', '${3:M}') ${4:-- muda a coluna original onde é T vira M}",
			"${5:--REPLACE(REPLACE(nome, 'T', 'M'), 't', 'm') AS coluna2 -- mantém coluna original e cria coluna editada}"
		],
		"description": "MUDAR_CARACTER_POR_OUTRO"
	},

	//EXTRAI_TRECHO_DE_STRING
	"EXTRAI_TRECHO_DE_STRING": {
		"scope": "sql",
		"prefix": "ZEXTR",
		"body": [
			"SUBSTRING(${1:COLUNA}, ${2:1}, ${3:3}) AS ${4:EXTRATOR}",
		],
		"description": "EXTRAI_TRECHO_DE_STRING"
	},

	//TRANSFORMAR_NUMERO_EM_STRING
	"TRANSFORMAR_NUMERO_EM_STRING": {
		"scope": "sql",
		"prefix": "ZEXTR",
		"body": [
			"STR(185.476, 6, 2)",
		],
		"description": "TRANSFORMAR_NUMERO_EM_STRING"
	},

	//DELETA_E_ACRESCENTA
	"DELETA_E_ACRESCENTA": {
		"scope": "sql",
		"prefix": "ZDEL_ACRES",
		"body": [
			"STUFF('SQL Tutorial', 1, 3, 'HTML') -- COMEÇA DA POSIÇÃO CATRACTER 1, APAGA 3 CARACTERES A PARTIR DE 1 E ACRESCENTA HTML",
		],
		"description": "DELETA_E_ACRESCENTA"
	},

	//TRANSFORMAR_EM_MAIUSCULA
	"TRANSFORMAR_EM_MAIUSCULA": {
		"scope": "sql",
		"prefix": "ZUPPER",
		"body": [
			"UPPER(${1:COLUNA})",
		],
		"description": "TRANSFORMAR_EM_MAIUSCULA"
	},

	//MÓDULO_DO_NUMERO
	"MÓDULO_DO_NUMERO": {
		"scope": "sql",
		"prefix": "ZMOD",
		"body": [
			"Abs(-243.5) AS MODULO",
		],
		"description": "MÓDULO_DO_NUMERO"
	},

	//MEDIA
	"MEDIA": {
		"scope": "sql",
		"prefix": "ZMED",
		"body": [
			"AVG(${1:COLUNA}) AS MEDIA",
		],
		"description": "MÉDIA"
	},

	//COUNT
	"COUNT": {
		"scope": "sql",
		"prefix": "ZCOUNT",
		"body": [
			"COUNT(${1:COLUNA}) AS TOTAL",
		],
		"description": "COUNT"
	},

	//MAIOR
	"MAIOR": {
		"scope": "sql",
		"prefix": "ZMAX",
		"body": [
			"MAX(${1:COLUNA}) AS MAIOR_VALOR",
		],
		"description": "MAIOR"
	},

	//MENOR
	"MENOR": {
		"scope": "sql",
		"prefix": "ZMIN",
		"body": [
			"MIN(${1:COLUNA}) AS MENOR_VALOR",
		],
		"description": "MENOR"
	},

	//ARREDONDAR
	"ARREDONDAR": {
		"scope": "sql",
		"prefix": "ZARRED",
		"body": [
			"ROUND(235.415, 0) AS ARREDONDADO",
		],
		"description": "ARREDONDAR"
	},

	//SOMAR
	"SOMAR": {
		"scope": "sql",
		"prefix": "ZSUM",
		"body": [
			"SUM(${1:COLUNA}) AS SOMA",
		],
		"description": "SOMAR"
	},

	//DATA_ATUAL
	"DATA_ATUAL": {
		"scope": "sql",
		"prefix": "ZDTATUAL",
		"body": [
			"CURRENT_TIMESTAMP",
		],
		"description": "DATA_ATUAL"
	},

	//EXTRAIR_DATA
	"EXTRAIR_DATA": {
		"scope": "sql",
		"prefix": "ZDTEXTR",
		"body": [
			"DATENAME(YEAR, '2017/08/25') AS DATE -- YEAR, MONTH, DAY",
		],
		"description": "EXTRAIR_DATA"
	},
	
	//CONVERTER
	"CONVERTER": {
		"scope": "sql",
		"prefix": "ZCONVERT",
		"body": [
			"CONVERT(int, 25.65)",
		],
		"description": "CONVERTER"
	},
	
	//IF
	"IF": {
		"scope": "sql",
		"prefix": "ZIF",
		"body": [
			"IIF(${1:COLUNA}>1, 'YES', 'NO') -- =, <>, !=, >, <", 
		],
		"description": "IF"
	},

	//NULIFICA
	"NULIFICA": {
		"scope": "sql",
		"prefix": "ZIF",
		"body": [
			"SELECT NULLIF(${1:COLUNA}, 25) AS SEM_25", 
		],
		"description": "NULIFICA"
	}

}
